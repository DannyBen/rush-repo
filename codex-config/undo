#!/usr/bin/env bash
source "$REPO_PATH/lib.sh"

start_marker="# start: rush codex-config"
end_marker="# end: rush codex-config"
config_file="$HOME/.codex/config.toml"

say "removing codex config patch"

changes_done=false

if [[ -f "$config_file" ]] && grep -qF "$start_marker" "$config_file"; then
  tmpfile="$(mktemp)"

  awk -v start="$start_marker" -v end="$end_marker" '
    $0 == start { skip = 1; next }
    $0 == end { skip = 0; drop_blank = 1; next }
    drop_blank && $0 == "" { drop_blank = 0; next }
    { drop_blank = 0 }
    !skip { print }
  ' "$config_file" > "$tmpfile"

  mv "$tmpfile" "$config_file"
  changes_done=true
fi

if [[ "$changes_done" = true ]]; then
  say "codex config patch removed: $config_file"
else
  say "no changes done"
fi
