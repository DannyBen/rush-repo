#!/usr/bin/env bash
source "$REPO_PATH/lib.sh"

config_file="$HOME/.codex/config.toml"

say "removing codex config patch"

config unset "$config_file" tui.keymap.composer.submit --if tab
config unset "$config_file" tui.keymap.composer.queue --if alt-q
config unset "$config_file" tui.keymap.editor.insert_newline --if enter
config array del "$config_file" sandbox_workspace_write.writable_roots "\$HOME/.cache"
